# ===== Puertos =====
# Puerto del servidor de stream de mercado (backend)
MARKET_STREAM_PORT=4500

# Puerto WS consumido por el frontend
NEXT_PUBLIC_STREAM_PORT=4500

# URL base para páginas legacy que consultan backend por HTTP
NEXT_PUBLIC_BACKEND_URL=http://localhost:4500

# URL base del frontend local
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3003

# ===== Intervalos de polling (ms) =====
# Nota: el código actual acepta intervalos por categoría vía options en startStreamServer.
# Estas variables sirven como convención de despliegue/configuración.
POLL_INTERVAL_FOREX_MS=4000
POLL_INTERVAL_INDICES_MS=7000
POLL_INTERVAL_STOCKS_MS=5000
POLL_INTERVAL_COMMODITIES_MS=6000

# ===== Toggles de proveedores =====
# Activar/desactivar proveedores/canales (1=activo, 0=inactivo)
ENABLE_PROVIDER_BINANCE_WS=1
ENABLE_PROVIDER_YAHOO_POLLING=1
ENABLE_PROVIDER_SYNTHETIC_FALLBACK=1

# Proveedor preferido por categoría (debe existir en config/symbols.json)
PREFERRED_PROVIDER_CRYPTO=binance
PREFERRED_PROVIDER_FOREX=twelvedata
PREFERRED_PROVIDER_INDICES=twelvedata
PREFERRED_PROVIDER_STOCKS=alpaca
PREFERRED_PROVIDER_COMMODITIES=twelvedata

# ===== Flags módulo opcional Ollama =====
# Si está en true, se permite enriquecer señales con LLM
OLLAMA_ENABLED=false
OLLAMA_ENDPOINT=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT_MS=10000
